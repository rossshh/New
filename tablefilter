import * as React from 'react';
import { alpha } from '@mui/material/styles';
import Box from '@mui/material/Box';
import Button from '@mui/material/Button';
import Checkbox from '@mui/material/Checkbox';
import InputAdornment from '@mui/material/InputAdornment';
import List from '@mui/material/List';
import ListItem from '@mui/material/ListItem';
import MenuItem from '@mui/material/MenuItem';
import Paper from '@mui/material/Paper';
import Popper from '@mui/material/Popper';
import Select, { SelectChangeEvent } from '@mui/material/Select';
import TextField from '@mui/material/TextField';
import Typography from '@mui/material/Typography';
import ArrowDropDownIcon from '@mui/icons-material/ArrowDropDown';
import SearchIcon from '@mui/icons-material/Search';

/* ---------- types ---------- */
export type FilterOp = 'eq' | 'neq' | 'gt' | 'lt';
export type TableFilterId = 'fall' | 'acuity' | 'gender' | 'age' | 'status' | (string & {});

/* ---------- props ---------- */
export interface TableFilterProps {
  id?: TableFilterId;
  label: string;
  op: FilterOp;
  setOp: (o: FilterOp) => void;
  value: string[];
  setValue: (v: string[]) => void;
  options: string[];
  placeholder?: string;
  open?: boolean;
  onOpen?: () => void;
  onClose?: () => void;
  onApply?: () => void;
}

function TableFilter({
  id,
  label,
  op,
  setOp,
  value,
  setValue,
  options,
  placeholder = 'All',
  open,
  onOpen,
  onClose,
  onApply,
}: TableFilterProps) {
  const isAge = id === 'age';

  const [q, setQ] = React.useState('');
  const [inputAge, setInputAge] = React.useState(value[0] ?? '');
  const [selectedOperator, setSelectedOperator] = React.useState<FilterOp>(op);
  React.useEffect(() => setSelectedOperator(op), [op]);
  React.useEffect(() => setInputAge(value[0] ?? ''), [value]);

  const hasSelection = isAge ? !!value[0] : value.length > 0;
  const lettersOnly = (s: string) => s.replace(/[^a-zA-Z\s]/g, '');

  const filtered = React.useMemo(() => {
    if (isAge) return options;
    const t = q.trim().toLowerCase();
    return t ? options.filter((o) => o.toLowerCase().includes(t)) : options;
  }, [q, options, isAge]);

  const toggle = (opt: string) => {
    if (isAge) return;
    setValue(value.includes(opt) ? value.filter((v) => v !== opt) : [...value, opt]);
  };

  const handleOperatorChange = (e: SelectChangeEvent<FilterOp>) => {
    const v = e.target.value as FilterOp;
    if (v) {
      setSelectedOperator(v);
      setOp(v);
    }
  };

  // const handleAgeChange = (e: React.ChangeEvent<HTMLInputElement>) => {
  //   const v = sanitizeNatural(e.target.value);
  //   setInputAge(v);
  //   if (v === '') setValue([]);
  //   else setValue([v]);
  // };

  const appliedRef = React.useRef(false);
  const openSnapshotValueRef = React.useRef<string[]>([]);
  const openSnapshotOpRef = React.useRef<FilterOp>(op);
  const controlled = typeof open === 'boolean';
  const [localOpen, setLocalOpen] = React.useState(false);
  const isOpen = controlled ? (open as boolean) : localOpen;
  const openDropdown = () => (controlled ? onOpen?.() : setLocalOpen(true));
  const closeDropdownRaw = () => (controlled ? onClose?.() : setLocalOpen(false));

  const closeDropdownWithMaybeRevert = React.useCallback(() => {
    if (!appliedRef.current) {
      setOp(openSnapshotOpRef.current);
      setValue(openSnapshotValueRef.current);
      setInputAge(openSnapshotValueRef.current[0] ?? '');
      setSelectedOperator(openSnapshotOpRef.current);
    }
    closeDropdownRaw();
  }, [setOp, setValue]);

  const rootRef = React.useRef<HTMLDivElement | null>(null);
  const buttonRef = React.useRef<HTMLButtonElement | null>(null);

  const handleTriggerClick = () => {
    if (isOpen) {
      closeDropdownWithMaybeRevert();
      return;
    }
    appliedRef.current = false;
    openSnapshotValueRef.current = value.slice();
    openSnapshotOpRef.current = op;
    openDropdown();
  };

  React.useEffect(() => {
    if (!isOpen) return;

    const handler = (e: Event) => {
      const t = e.target as Node | null;
      if (rootRef.current && t && !rootRef.current.contains(t)) {
        closeDropdownWithMaybeRevert();
      }
    };

    document.addEventListener('pointerdown', handler, true);
    document.addEventListener('click', handler, true);

    return () => {
      document.removeEventListener('pointerdown', handler, true);
      document.removeEventListener('click', handler, true);
    };
  }, [isOpen, closeDropdownWithMaybeRevert]);

  return (
    <Box
      ref={rootRef}
      tabIndex={-1}
      onKeyDown={(e) => {
        if (e.key === 'Escape') {
          e.stopPropagation();
          closeDropdownWithMaybeRevert();
        }
      }}
      sx={{
        outline: 'none',
        display: { xs: 'block', sm: 'inline-block' },
        width: { xs: '100%', sm: 'auto' },
      }}
    >
      <Button
        ref={buttonRef}
        variant="outlined"
        size="small"
        onClick={handleTriggerClick}
        sx={(theme) => {
          const highlight = {
            backgroundColor: theme.palette.action.selected,
            borderColor: theme.palette.primary.main,
            borderWidth: '2px',
          };

          const isHighlighted = hasSelection || isOpen;

          return {
            height: 32,
            borderRadius: '6px',
            borderColor: theme.palette.divider,
            backgroundColor: theme.palette.background.paper,
            px: 1,
            display: 'inline-flex',
            alignItems: 'center',
            gap: 0.75,
            whiteSpace: 'nowrap',
            width: { xs: '100%', sm: 'auto' },
            maxWidth: { xs: '100%', sm: 360 },
            boxShadow: '0px 1px 2px 0px rgba(0, 0, 0, 0.08)',
            textTransform: 'none',
            '&:hover': { backgroundColor: theme.palette.action.hover },
            '&:focus-visible': {
              outline: 'none',
              borderColor: theme.palette.primary.main,
              borderWidth: '2px',
              boxShadow: `0 0 0 3px ${alpha(theme.palette.primary.main, 0.2)}`,
            },
            ...(isHighlighted && highlight),
          };
        }}
      >
        <Typography variant="body2" fontWeight={600} sx={{ mr: hasSelection ? 0.25 : 0 }}>
          {label}
        </Typography>

        {hasSelection && (
          <>
            <Box
              component="span"
              sx={{
                fontFamily: 'monospace',
                fontSize: 12,
                lineHeight: 1,
                px: 0.5,
                py: 0.25,
                borderRadius: '6px',
                bgcolor: 'action.selected',
                color: 'text.primary',
              }}
            >
              {selectedOperator === 'eq'
                ? '='
                : selectedOperator === 'neq'
                  ? '!='
                  : selectedOperator === 'gt'
                    ? '>'
                    : '<'}
            </Box>

            <Typography variant="body2" sx={{ overflow: 'hidden', textOverflow: 'ellipsis', maxWidth: 120 }}>
              {isAge ? value[0] : value[0] ?? placeholder}
            </Typography>

            {!isAge && value.length > 1 && (
              <Box
                component="span"
                sx={(theme) => ({
                  ml: 0.25,
                  px: 0.5,
                  borderRadius: '6px',
                  fontSize: 12,
                  lineHeight: 1.4,
                  bgcolor: alpha(theme.palette.primary.main, 0.16),
                  color: theme.palette.primary.main,
                })}
              >
                +{value.length - 1}
              </Box>
            )}
          </>
        )}

        <ArrowDropDownIcon sx={{ ml: 1.25 }} />
      </Button>

      <Popper
        open={isOpen}
        anchorEl={buttonRef.current}
        placement="bottom-end"
        disablePortal
        sx={{ zIndex: 1300 }}
      >
        <Paper
          variant="outlined"
          sx={{
            minWidth: { xs: '93%', sm: 340 },
            maxWidth: '100%',
            p: 1,
            mt: 0.5,
            display: 'flex',
            flexDirection: 'column',
            gap: 1,
            borderRadius: '10px',
            overflow: 'visible',
            boxShadow: 3,
          }}
        >
          {/* Operator */}
          <Box onMouseDown={(e) => e.stopPropagation()} onClick={(e) => e.stopPropagation()}>
            <Select<FilterOp>
              size="small"
              value={selectedOperator}
              onChange={handleOperatorChange}
              IconComponent={ArrowDropDownIcon}
              fullWidth
              MenuProps={{
                disablePortal: true,
                PaperProps: {
                  onMouseDown: (e: React.MouseEvent) => e.stopPropagation(),
                  onClick: (e: React.MouseEvent) => e.stopPropagation(),
                  sx: isAge
                    ? { maxHeight: 'calc(2 * 36px + 8px)', overflowY: 'auto', zIndex: 1501 }
                    : { maxHeight: 'unset', overflowY: 'visible', zIndex: 1501 },
                },
              }}
              sx={{
                '& .MuiSelect-select': { minHeight: '36px !important', display: 'flex', alignItems: 'center' },
                width: '100%',
              }}
            >
              <MenuItem value="eq" sx={{ minHeight: 36 }}>{label} = (equals)</MenuItem>
              {!isAge && <MenuItem value="neq" sx={{ minHeight: 36 }}>{label} != (not equals)</MenuItem>}
              {isAge && <MenuItem value="gt" sx={{ minHeight: 36 }}>{label} &gt; (greater than)</MenuItem>}
              {isAge && <MenuItem value="lt" sx={{ minHeight: 36 }}>{label} &lt; (less than)</MenuItem>}
            </Select>
          </Box>

          {/* Content */}
          {isAge ? (
            <Box
              sx={{ mt: 2 }}
              onMouseDown={(e) => e.stopPropagation()}
              onClick={(e) => e.stopPropagation()}
            >
              <TextField
                id="age-input"
                size="small"
                type="number"
                placeholder="Enter Age"
                value={inputAge}
                fullWidth
                onChange={(e) => {
                  let digits = e.target.value.replace(/\D+/g, '');
                  if (digits.length > 1) digits = digits.replace(/^0+/, '') || '0';

                  setInputAge(digits);
                  setValue(digits ? [digits] : []);
                }}
                inputProps={{
                  min: 1,
                  step: 1,
                  inputMode: 'numeric',
                  pattern: '[1-9][0-9]*',
                  onPaste: (e: React.ClipboardEvent<HTMLInputElement>) => {
                    e.preventDefault();
                    const text = (e.clipboardData || (window as any).clipboardData)?.getData('text') ?? '';
                    let digits = text.replace(/\D+/g, '');
                    if (digits.length > 1) digits = digits.replace(/^0+/, '') || '0';
                    setInputAge(digits);
                    setValue(digits ? [digits] : []);
                  },
                  onKeyDown: (e: React.KeyboardEvent<HTMLInputElement>) => {
                    const allowed = ['Backspace', 'Delete', 'Tab', 'ArrowLeft', 'ArrowRight', 'Home', 'End'];
                    if (allowed.includes(e.key)) return;
                    if (['e', 'E', '+', '-', '.', ','].includes(e.key)) { e.preventDefault(); return; }
                    if (!/^\d$/.test(e.key)) e.preventDefault();
                  },
                  onWheel: (e: React.WheelEvent<HTMLInputElement>) => { (e.target as HTMLInputElement).blur(); },
                  onBlur: () => {
                    const n = parseInt(inputAge, 10);
                    if (!Number.isFinite(n) || n < 1) {
                      setInputAge('');
                      setValue([]);
                    } else {
                      const s = String(n);
                      setInputAge(s);
                      setValue([s]);
                    }
                  },
                }}
              />
            </Box>

          ) : (
            <>
              <TextField
                size="small"
                placeholder={`Search ${label}`}
                value={q}
                fullWidth
                onChange={(e) => setQ(lettersOnly(e.target.value))}
                onPaste={(e) => {
                  e.preventDefault();
                  const text = (e.clipboardData || (window as any).clipboardData).getData('text');
                  setQ((prev) => lettersOnly(prev + text));
                }}
                autoComplete="off"
                inputProps={{ inputMode: 'text' }}
                InputProps={{
                  startAdornment: (
                    <InputAdornment position="start">
                      <SearchIcon fontSize="small" />
                    </InputAdornment>
                  ),
                }}
                onMouseDown={(e) => e.stopPropagation()}
                onClick={(e) => e.stopPropagation()}
              />
              <Box
                sx={{
                  maxHeight: 260,
                  overflowY: 'auto',
                  overflowX: 'hidden',
                  borderRadius: 1,
                  border: '1px solid',
                  borderColor: 'divider',
                }}
              >
                <List dense disablePadding>
                  {filtered.map((opt) => {
                    const checked = value.includes(opt);
                    return (
                      <ListItem
                        key={`${id ?? label}-${opt}`}
                        sx={{ py: 0.5, px: 1, cursor: 'pointer', '&:hover': { backgroundColor: 'action.hover' } }}
                        onClick={(e) => {
                          e.stopPropagation();
                          toggle(opt);
                        }}
                      >
                        <Checkbox checked={checked} onChange={() => toggle(opt)} size="small" sx={{ mr: 1, p: 0 }} />
                        <Typography variant="body2">{opt}</Typography>
                      </ListItem>
                    );
                  })}
                  {filtered.length === 0 && (
                    <ListItem sx={{ py: 1, px: 1.5 }}>
                      <Typography variant="body2" color="text.secondary">
                        No results
                      </Typography>
                    </ListItem>
                  )}
                </List>
              </Box>
            </>
          )}

          {/* Footer */}
          <Box sx={{ display: 'flex', gap: 1, mt: 1 }} onMouseDown={(e) => e.stopPropagation()} onClick={(e) => e.stopPropagation()}>
            <Button
              size="small"
              variant="outlined"
              disabled={!hasSelection}
              aria-label={isAge ? 'Clear age input' : 'Clear selection'}
              onClick={() => {
                setValue([]);
                if (isAge) setInputAge('');
              }}
              sx={{ textTransform: 'none' }}
            >
              {isAge ? 'Clear input' : 'Clear selection'}
            </Button>
            <Box sx={{ flex: 1 }} />
            <Button
              size="small"
              variant="contained"
              onClick={() => {
                appliedRef.current = true;
                onApply?.();
                closeDropdownRaw();
              }}
              sx={{ textTransform: 'none' }}
            >
              Apply
            </Button>
          </Box>
        </Paper>
      </Popper>
    </Box>
  );
}

export default React.memo(TableFilter);
