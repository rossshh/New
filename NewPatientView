function acuityName(code: string | null | undefined): string {
  if (!code) return '';
  switch ((code || '').toUpperCase()) {
    case 'RED': return 'Critical';
    case 'YELLOW': return 'Observation';
    case 'GREEN': return 'Stable';
    default: return code;
  }
}

