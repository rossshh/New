  // signalR, period change, carePlan flow, pulse — all unchanged logic omitted for brevity but included below
  const baseurl = import.meta.env.VITE_BASE_URL;
  const EMPTY_BUNDLE: any = { entry: [] };
  const resourceDisplayName: Record<string, string> = {
    Observation: 'Observations', CarePlan: 'Care Plans', AllergyIntolerance: 'Allergies',
