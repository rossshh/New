  const refreshOverview = () => { setOverviewInitailized(true); void fetchOveriewVitals(); void fetchAiOverview(); };
  const refreshAdtRecords = () => { setTabError('adtRecords', ''); setAdtRecords([]); setAdtPage(1); setAdtTotalItems(0); void fetchADT(1); };
  const refreshProgressRecords = () => { setTabError('progressNotes', ''); setProgressRecords([]); setProgressPage(1); setProgressTotalItems(0); void fetchProgress(1); };

  const loadfaultTab = (tabId: TabId) => {
    if (tabId === 'overview' && !overviewInitailized) refreshOverview();
    if (tabId === 'summary' && !summaryAnalytics) void fetchSummaryAnalytics();
    if (tabId === 'ai' && !composition48h && !analysisError) void fetchAiOverview();
