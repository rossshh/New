    }

    if (loadingTabs[tabId]) return renderSkeletonForTab(tabId);
    if (errorTabs[tabId]) return <Alert severity="error">{errorTabs[tabId]}</Alert>;
    const bundle = tabData[tabId];

    switch (tabId) {
      case 'summary': return <PatientGoalsSummary analytics={summaryAnalytics} loading={summaryAnalyticsLoading} error={summaryAnalyticsError} tasksData={patientTasks} tasksLoading={patientTasksLoading} tasksError={patientTasksError} canListObservation={canListObservation} onViewMoreVitals={() => { setSelectedTabId('vitals'); handleTabClick('vitals'); }} />;
      case 'ai':
        if (analysisError) return <Alert severity="error" action={<Button color="inherit" size="small" onClick={() => void fetchAiOverview()}>Retry</Button>}>{analysisError}</Alert>;
        return <OverviewSection careTeam={[]} compliance={compliance} composition48h={composition48h} />;
      case 'devices': { const inventory = tabData.devices as PatientInventoryResponse | null; return <PatientDevices gateways={inventory?.gateways ?? []} ungrouped={inventory?.ungroupedDevices ?? []} gatewayInfosByUuid={gatewayInfosByUuid} />; }
      case 'careTeam': return bundle ? <CareTeam bundle={bundle} /> : null;
      case 'transcript': return <PatientCallHistory patientName={name} response={{ data: callHistoryRows, meta: callHistoryMeta }} loading={callHistoryLoading} error={callHistoryError} onRetry={() => void fetchCallHistory(callHistoryMeta.pageIndex ?? 1)} onPageChange={p => void fetchCallHistory(p)} />;
      case 'conditions': return bundle ? <Conditions bundle={bundle} /> : null;
      case 'allergies': return bundle ? <Allergies bundle={bundle} /> : null;
      case 'immunizations': return bundle ? <Immunizations bundle={bundle} /> : null;
      case 'medications': return !canListMedicationRequest ? <Alert severity="warning">Access Restricted: You don't have permission to view Medications.</Alert> : (bundle ? <Medications bundle={bundle} /> : null);
      case 'activities': return <PatientEventType patientId={patientDBId} data={{ currentMonth: eventTypesCurrentMonth, previousMonths: eventTypesPreviousMonths }} loading={eventTypesLoading} error={eventTypesError} onRetry={() => void fetchEventTypes()} />;
      case 'reports': return bundle ? <DiagnosticReport bundle={bundle} /> : null;
      case 'documents': return bundle ? <PatientDocuments bundle={bundle} /> : null;
      case 'adtRecords': return <ADTRecords response={{ data: adtRecords, meta: { totalItems: adtTotalItems, pageIndex: adtPage, totalPages: adtTotalPages } }} onPageChange={page => { setAdtPage(page); fetchADT(page); }} />;
      case 'nutrition': return (
        <Box>
          <Tabs value={ordersSubTab} onChange={(_, val) => setOrdersSubTab(val)} variant="scrollable" TabIndicatorProps={{ sx: { top: 0, bottom: 'unset', height: 2, bgcolor: '#1976d2' } }} sx={{ px: 1, minHeight: 'auto', '& .MuiTab-root': { textTransform: 'none', minHeight: 'auto', px: 2, py: 1.2, fontSize: 13, fontWeight: 500 }, '& .Mui-selected': { backgroundColor: '#e3f2fd', color: '#1976d2' } }}>
            <Tab label={<Stack direction="row" alignItems="center" spacing={1}><RestaurantIcon /><Typography variant="body2">Nutrition Orders</Typography></Stack>} />
            <Tab label={<Stack direction="row" alignItems="center" spacing={1}><Pill size={16} strokeWidth={3} /><Typography variant="body2">Supplement Orders</Typography></Stack>} />
          </Tabs>
          <Divider sx={{ mt: 0, mb: 4 }} />
          {ordersSubTab === 0 ? <Nutrition patientId={patinentId} refreshToken={nutritionRefreshToken} /> : <SupplementOrders patientId={patinentId} refreshToken={nutritionRefreshToken} />}
        </Box>
      );
      case 'careprofile': return <Careprofile response={bundle} />;
      case 'alerts': return <PatientAlerts patientId={patientDBId} patientName={name} items={alertsItems} hasMore={alertsHasMore} counts={alertsCounts} filter={alertsFilter} loading={alertsLoading} loadingMore={alertsLoadingMore} error={alertsError} onFilterChange={v => { setAlertsFilter(v); refreshAlerts(v); }} onLoadMore={() => { if (alertsLoading || alertsLoadingMore || !alertsHasMore) return; void fetchPatientAlerts(alertsPageIndex + 1, 'append'); }} onRetry={() => refreshAlerts()} />;
      case 'pccCarePlan': {
        const careplanBlock = tabData?.pccCarePlan?.careplan, kardexBlock = tabData?.pccCarePlan?.kardex;
        const isCareplan = pccSubTab === 0;
        const activeLoading = isCareplan ? loadingTabs[PCC_CAREPLAN_KEY] : loadingTabs[PCC_KARDEX_KEY];
        const activeError = isCareplan ? errorTabs[PCC_CAREPLAN_KEY] : errorTabs[PCC_KARDEX_KEY];
        return (
          <Box>
            <Tabs value={pccSubTab} onChange={(_, val) => { setPccSubTab(val); if (val === 1 && !tabData?.pccCarePlan?.kardex && !loadingTabs[PCC_KARDEX_KEY]) void fetchPccCareplanKardex(1); if (val === 0 && !tabData?.pccCarePlan?.careplan && !loadingTabs[PCC_CAREPLAN_KEY]) void fetchPccCareplan(1); }} variant="scrollable" TabIndicatorProps={{ sx: { top: 0, bottom: 'unset', height: 2, bgcolor: '#1976d2' } }} sx={{ px: 1, minHeight: 'auto', '& .MuiTab-root': { textTransform: 'none', minHeight: 'auto', px: 2, py: 1.2, fontSize: 13, fontWeight: 500 }, '& .Mui-selected': { backgroundColor: '#e3f2fd', color: '#1976d2' } }}>
              <Tab label={<Stack direction="row" alignItems="center" spacing={1}><LocalHospital /><Typography variant="body2">Care plan</Typography></Stack>} />
              <Tab label={<Stack direction="row" alignItems="center" spacing={1}><FormatListBulleted /><Typography variant="body2">Care plan kardex</Typography></Stack>} />
            </Tabs>
            <Divider sx={{ mt: 0, mb: 2 }} />
            {activeLoading && renderSkeletonForTab('pccCarePlan')}
            {!activeLoading && !!activeError && <Alert severity="error" action={<Button color="inherit" size="small" onClick={() => { if (isCareplan) void fetchPccCareplan(1); else void fetchPccCareplanKardex(1); }}>Retry</Button>}>{activeError}</Alert>}
            {!activeLoading && !activeError && (isCareplan ? <PccCareplanRecords response={careplanBlock} onPageChange={page => void fetchPccCareplan(page)} /> : <CareplanKardexRecords response={kardexBlock} onPageChange={page => void fetchPccCareplanKardex(page)} />)}
          </Box>
        );
      }
      case 'episodesOfCare': return <EpisodeOfCareRecords response={bundle} onPageChange={page => void fetchCareEpisodeOfCare(page)} />;
      case 'incidents': return <IncidentList rows={incidentRows} />;
      case 'progressNotes': return <ProgressNotes response={{ data: progressRecords, meta: { totalItems: progressTotalItems, pageIndex: progressPage, totalPages: progressTotalPages } }} onPageChange={page => { setProgressPage(page); fetchProgress(page); }} onDetailsError={handleProgressDetailsError} patientHealthLakeId={patientId} onRefresh={refreshProgressRecords} />;
      case 'contacts': return <EmergencyContactsRecords response={{ data: emergencyContacts, meta: { pageIndex: emergencyMeta.pageIndex, totalPages: emergencyMeta.totalPages, totalItems: emergencyMeta.totalItems } }} onPageChange={page => void fetchEmergencyContanct(page)} />;
      case 'coverage': return <Coverage bundle={tabData.coverage} />;
      case 'adl': {
        const assessmentBundle = tabData?.adl?.assessment, scoreBundle = tabData?.adl?.score;
        const isAssessment = adlSubTab === 0;
        const activeLoading = isAssessment ? loadingTabs[ADL_ASSESSMENT_KEY] : loadingTabs[ADL_SCORE_KEY];
        const activeError = isAssessment ? errorTabs[ADL_ASSESSMENT_KEY] : errorTabs[ADL_SCORE_KEY];
        return (
          <Box>
            <Tabs value={adlSubTab} onChange={(_, val) => { setAdlSubTab(val); if (val === 1 && !tabData?.adl?.score && !loadingTabs[ADL_SCORE_KEY]) void fetchAdlScore(); if (val === 0 && !tabData?.adl?.assessment && !loadingTabs[ADL_ASSESSMENT_KEY]) void fetchAdlAssessment(); }} variant="scrollable" TabIndicatorProps={{ sx: { top: 0, bottom: 'unset', height: 2, bgcolor: '#1976d2' } }} sx={{ px: 1, minHeight: 'auto', '& .MuiTab-root': { textTransform: 'none', minHeight: 'auto', px: 2, py: 1.2, fontSize: 13, fontWeight: 500 }, '& .Mui-selected': { backgroundColor: '#e3f2fd', color: '#1976d2' } }}>
              <Tab label={<Stack direction="row" alignItems="center" spacing={1}><ChecklistIcon /><Typography variant="body2">ADL Assessment</Typography></Stack>} />
              <Tab label={<Stack direction="row" alignItems="center" spacing={1}><FormatListBulleted /><Typography variant="body2">ADL Score</Typography></Stack>} />
            </Tabs>
            <Divider sx={{ mt: 0, mb: 2 }} />
            {activeLoading && renderSkeletonForTab('adl')}
            {!activeLoading && !!activeError && <Alert severity="error" action={<Button color="inherit" size="small" onClick={() => { if (isAssessment) void fetchAdlAssessment(); else void fetchAdlScore(); }}>Retry</Button>}>{activeError}</Alert>}
            {!activeLoading && !activeError && (isAssessment ? <AdlAssessment fhirResponse={assessmentBundle} /> : <AdlScore fhirResponse={scoreBundle} />)}
          </Box>
        );
      }
      default: return null;
    }
  };

  // ─── RENDER ───────────────────────────────────────────────────────────────
  return (
    <Box sx={{ display: 'flex', height: '100%', overflow: 'hidden', bgcolor: '#F7F8FA' }}>

      {/* ── LEFT SIDEBAR ── */}
      <Box
        sx={{
          width: 210,
          flexShrink: 0,
          bgcolor: '#FFFFFF',
          borderRight: '1px solid #E8E8E8',
          display: 'flex',
          flexDirection: 'column',
          overflowY: 'auto',
          pt: 2,
          pb: 3,
        }}
      >
        {visibleNavGroups.map((group) => (
          <Box key={group.heading} sx={{ mb: 1.5, px: 1.5 }}>
            <Typography
              variant="caption"
              sx={{ fontWeight: 600, color: '#999', textTransform: 'uppercase', letterSpacing: '0.06em', fontSize: 10.5, px: 0.5, display: 'block', mb: 0.5 }}
            >
              {group.heading}
            </Typography>
            <Box sx={{ display: 'flex', flexDirection: 'column', gap: 0.25 }}>
              {group.tabs.map(tab => (
                <SideNavItem
                  key={tab.id}
                  tab={tab}
                  selected={selectedTabId === tab.id}
                  loading={loadingTabs[tab.id]}
                  onClick={() => { setSelectedTabId(tab.id); handleTabClick(tab.id); }}
                />
              ))}
            </Box>
          </Box>
        ))}
      </Box>

      {/* ── MAIN AREA ── */}
      <Box sx={{ flex: 1, display: 'flex', flexDirection: 'column', overflow: 'hidden' }}>

        {/* ── PATIENT HEADER BAR ── */}
        <Box
          sx={{
            bgcolor: '#FFFFFF',
            borderBottom: '1px solid #E8E8E8',
            px: 3,
            py: 1.75,
            display: 'flex',
            alignItems: 'center',
            gap: 2,
            flexWrap: 'wrap',
          }}
        >
          {/* Avatar + info */}
          <Avatar
            alt={name}
            src={!avatarFailed ? patient.photo?.dataUrl : undefined}
            imgProps={{ onError: () => setAvatarFailed(true), referrerPolicy: 'no-referrer' }}
            sx={{ width: 44, height: 44, fontSize: 18, bgcolor: '#1565C0', flexShrink: 0 }}
          >
            {initials || '?'}
          </Avatar>

          <Box sx={{ minWidth: 0 }}>
            <Typography variant="subtitle1" fontWeight={700} lineHeight={1.2}>
              {name}
            </Typography>
            <Typography variant="caption" color="text.secondary">
              {age}y, {gender.charAt(0).toUpperCase()}{gender.slice(1)} · MRN {mrn}
              {locationParts.length > 0 && ` · ${locationParts.join(' ')}`}
              {patient.billingPractioner?.fullName && ` · ${patient.billingPractioner.fullName}`}
            </Typography>
          </Box>

          {/* Status chips */}
          <Stack direction="row" spacing={0.75} flexWrap="wrap" sx={{ ml: 0.5 }}>
            {headerChips.map((chip, i) => (
              <Chip
                key={i}
                label={chip.label}
                size="small"
                icon={chip.icon}
                color={chip.color}
                variant="outlined"
                sx={{ fontSize: 12, fontWeight: 500, height: 26, borderRadius: '6px' }}
              />
            ))}
          </Stack>

          {/* Spacer */}
          <Box sx={{ flex: 1 }} />

          {/* Call button (clinic only) */}
          {picklist?.tenant === 'clinic' && (
            <Button
              variant="contained"
              startIcon={<CallIcon />}
              onClick={() => openCall({ toNumberE164: dialTo, patientId: patientDBId, displayNumber: formattedPhone ?? phone, selectedFacilityId, title: name })}
              disabled={!dialTo}
              size="small"
              sx={{ borderRadius: '8px', textTransform: 'none', fontWeight: 600, whiteSpace: 'nowrap', px: 2, py: 1 }}
            >
              {`Call ${(patient?.firstName ?? '').trim()} ${(patient?.lastName ?? '').trim()}`.trim()}
            </Button>
          )}
        </Box>

        {/* ── ALERT BANNER ── */}
        {picklist?.tenant === 'clinic' && unresolvedAlertsCount > 0 && (
          <Box sx={{ px: 3, pt: 1.5 }}>
            <Alert
              severity="error"
              sx={{ borderRadius: '8px' }}
              action={
                <Button size="small" variant="outlined" sx={{ textTransform: 'none', fontWeight: 500, color: 'error.main', borderColor: 'error.main', mx: 1, bgcolor: '#fff' }}
                  onClick={() => { setSelectedTabId('alerts'); handleTabClick('alerts'); }}
                >
                  View alerts
                </Button>
              }
            >
              {name} has <b>{unresolvedAlertsCount}</b> unresolved alerts.
            </Alert>
          </Box>
        )}

        {analysisError && (
          <Box sx={{ px: 3, pt: 1.5 }}>
            <Alert severity="warning">{analysisError}</Alert>
          </Box>
        )}

        {/* ── TAB CONTENT ── */}
        <Box sx={{ flex: 1, overflowY: 'auto', px: 3, pt: 2.5, pb: 3 }} ref={activityContainerRef}>
          {visibleTabs.map(tab => (
            <TabPanel key={tab.id} value={selectedTabId} tabId={tab.id}>
              <Suspense fallback={renderSkeletonForTab(tab.id)}>
                {renderTabContent(tab.id)}
              </Suspense>
            </TabPanel>
          ))}
        </Box>
      </Box>
    </Box>
  );
}
