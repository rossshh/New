    setEventTypesLoading(false); setEventTypesError(null); setEventTypesCurrentMonth(null); setEventTypesPrevByStart({});
    setAlertsFilter('Unresolved'); setAlertsItems([]); setAlertsHasMore(true); setAlertsPageIndex(1); setAlertsLoading(false); setAlertsLoadingMore(false); setAlertsError(null);
    setAlertsCounts({ all: 0, unresolved: 0, resolved: 0 }); setAlertsInitialized(false);
    alertsSeenRef.current = new Set(); alertsLastQueryKeyRef.current = '';
    alertsAbortRef.current?.abort(); alertsAbortRef.current = null; alertsInFlightRef.current = false;
    hasClosedParentPageEventRef.current = false;
  }, [patient]);

  // CarePlan flow
  type CarePlanFlowState = 'idle' | 'waiting' | 'fetching' | 'error';
  const [carePlanFlow, setCarePlanFlow] = useState<{ state: CarePlanFlowState; message: string }>({ state: 'idle', message: '' });
  const carePlanTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const carePlanRetryCountRef = useRef(0);
  const clearCarePlanTimer = () => { if (carePlanTimerRef.current) { clearTimeout(carePlanTimerRef.current); carePlanTimerRef.current = null; } };

  const fetchCarePlanOnce = async () => {
    try {
      setCarePlanFlow({ state: 'fetching', message: 'Fetching updated care plan…' });
      const body = buildBody('CarePlan');
      const bundle = await fhirRequest({ resourceType: 'CarePlan', selectedFacilityId, body });
      const hasEntries = Array.isArray(bundle?.entry) && bundle.entry.length > 0;
      setTabBundle('carePlan', bundle);
      if (hasEntries) { setCarePlanFlow({ state: 'idle', message: '' }); carePlanRetryCountRef.current = 0; clearCarePlanTimer(); }
      else if (carePlanRetryCountRef.current < 1) {
        carePlanRetryCountRef.current += 1;
        setCarePlanFlow({ state: 'waiting', message: 'Fetching care plan. This may take a few moments…' });
        clearCarePlanTimer(); carePlanTimerRef.current = setTimeout(fetchCarePlanOnce, 10000);
      } else { setCarePlanFlow({ state: 'error', message: 'Careplan being updated. Please try refreshing again' }); clearCarePlanTimer(); }
    } catch (e: any) { setCarePlanFlow({ state: 'error', message: e?.message || 'Something went wrong fetching care plan.' }); clearCarePlanTimer(); }
  };

  const startCarePlanRefreshFlow = () => {
    carePlanRetryCountRef.current = 0;
    setCarePlanFlow({ state: 'waiting', message: 'Fetching updated care plan…' });
    clearCarePlanTimer(); carePlanTimerRef.current = setTimeout(fetchCarePlanOnce, 5000);
  };

  useEffect(() => () => { clearCarePlanTimer(); }, []);
  useEffect(() => { clearCarePlanTimer(); carePlanRetryCountRef.current = 0; setCarePlanFlow({ state: 'idle', message: '' }); }, [patientId]);

  const dialTo = React.useMemo(() => {
    const raw = (phone || '').trim(); if (!raw) return '';
    if (raw.startsWith('+')) return raw;
    const digits = raw.replace(/\D/g, '');
    if (digits.length === 10) return `+1${digits}`;
    if (digits.length === 11 && digits.startsWith('1')) return `+${digits}`;
