      setVitalsData(prev => ({ ...prev, [selectedVital]: bundle }));
      setLoadedExtentPerVital(prev => {
        const current = prev[selectedVital] ?? 'today';
        const nextExtent = extentRank[period] > extentRank[current] ? period : current;
        return { ...prev, [selectedVital]: nextExtent };
      });
      setRawVitals(prev => {
        const currentExtent = loadedExtentPerVital[selectedVital] ?? 'today';
        if (extentRank[period] > extentRank[currentExtent]) return { ...prev, [selectedVital]: bundle };
