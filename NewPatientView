        return { ...measure, total: filtered.length + 1, data: [reading, ...filtered] };
      });
      if (!foundLatestMeasure) nextResults.push({ measure: 'latestVitalsByType', type: 'LATEST', total: 1, data: [reading] });
      return { ...prev, size: nextResults.length, results: nextResults };
