    const pick = (s?: string | null) => (typeof s === 'string' && s.trim() ? s.trim() : '');
    const f = pick(first), l = pick(last);
    if (f && l) return (f[0] + l[0]).toUpperCase();
    const full = pick(fullName);
    if (!full) return '';
    const prefixes = ['mr', 'mrs', 'ms', 'miss', 'dr', 'prof', 'sir', 'madam', 'mx'];
    const tokens = full.replace(/\s+/g, ' ').trim().split(' ').filter(Boolean);
    const head = tokens[0]?.replace(/\./g, '').toLowerCase();
    const startIdx = prefixes.includes(head) ? 1 : 0;
    const core = tokens.slice(startIdx);
    if (core.length === 0) return '';
    if (core.length === 1) return core[0][0].toUpperCase();
    return (core[0][0] + core[core.length - 1][0]).toUpperCase();
  };

