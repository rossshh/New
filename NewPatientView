  }, [phone]);

  const sendPulse = useCallback(async (activityAtIso: string) => {
    if (!selectedFacilityId || !currentEventLogId) return;
    await pushPulseActivity(selectedFacilityId, currentEventLogId, activityAtIso);
  }, [selectedFacilityId, currentEventLogId]);

  useActivityPulse({
    enabled: picklist?.tenant === 'clinic' && !!selectedFacilityId && !!currentEventLogId,
    selectedFacilityId: selectedFacilityId ?? '', eventLogId: currentEventLogId, sendPulse, intervalMs: 60_000, activityThrottleMs: 100, target: window,
  });

  // signalR
  useEffect(() => {
    let isMounted = true;
    (async () => {
      if (!canListObservation) return;
      if (connectionRef.current) {
        connectionRef.current.off('ReceiveVitalsUpdate');
        try { await connectionRef.current.invoke('UnsubscribeFromPatient', patientId); } catch { }
        try { await connectionRef.current.stop(); } catch { }
      }
      const conn = new signalR.HubConnectionBuilder()
        .withUrl(`${baseurl}/vitalshub?patientId=${patientId}`, { transport: signalR.HttpTransportType.WebSockets, withCredentials: true })
        .withAutomaticReconnect().configureLogging(signalR.LogLevel.Information).build();
      conn.on('ReceiveVitalsUpdate', (data: any) => {
        if (!isMounted) return;
        const { timestamp: iso, measurements } = data;
        const push = (key: string, resource: any, readings?: VitalReading | VitalReading[]) => {
          setVitalsData(prev => ({ ...prev, [key]: { entry: [...(prev[key]?.entry ?? []), { resource }] } }));
          if (readings) { const list = Array.isArray(readings) ? readings : [readings]; list.forEach(upsertLatestVitalInSummaryAnalytics); }
        };
        if (measurements?.oxygenSaturation?.value != null) { const value = measurements.oxygenSaturation.value; push('spo2', { resourceType: 'Observation', effectiveDateTime: iso, valueQuantity: { value, unit: '%' } }, { vitalTypeCode: '59408-5', eventId: data?.eventId ?? `${patientId}-spo2-${iso}`, measurementKey: 'oxygenSaturation', valueNum: value, unit: '%', measuredAt: iso }); }
        if (measurements?.bloodGlucose?.value != null) { const value = measurements.bloodGlucose.value; push('bloodGlucose', { resourceType: 'Observation', effectiveDateTime: iso, valueQuantity: { value, unit: 'mg/dL' } }, { vitalTypeCode: '2339-0', eventId: data?.eventId ?? `${patientId}-bloodGlucose-${iso}`, measurementKey: 'bloodGlucose', valueNum: value, unit: 'mg/dL', measuredAt: iso }); }
        if (measurements?.heartRate?.value != null) { const value = measurements.heartRate.value; push('heartRate', { resourceType: 'Observation', effectiveDateTime: iso, valueQuantity: { value, unit: 'bpm' } }, { vitalTypeCode: '8867-4', eventId: data?.eventId ?? `${patientId}-heartRate-${iso}`, measurementKey: 'heartRate', valueNum: value, unit: 'bpm', measuredAt: iso }); }
        if (measurements?.bodyWeight?.value != null) { const value = measurements.bodyWeight.value; push('bodyWeight', { resourceType: 'Observation', effectiveDateTime: iso, valueQuantity: { value, unit: 'lbs' } }, { vitalTypeCode: '29463-7', eventId: data?.eventId ?? `${patientId}-bodyWeight-${iso}`, measurementKey: 'bodyWeight', valueNum: value, unit: 'lbs', measuredAt: iso }); }
        if (measurements?.bodyTemperature?.value != null) { const value = measurements.bodyTemperature.value; push('bodyTemperature', { resourceType: 'Observation', effectiveDateTime: iso, valueQuantity: { value, unit: '°F' } }, { vitalTypeCode: '8310-5', eventId: data?.eventId ?? `${patientId}-bodyTemperature-${iso}`, measurementKey: 'bodyTemperature', valueNum: value, unit: '°F', measuredAt: iso }); }
        if (measurements?.painLevel?.value != null) { const value = measurements.painLevel.value; push('painLevel', { resourceType: 'Observation', effectiveDateTime: iso, valueQuantity: { value, unit: '' } }, { vitalTypeCode: '72514-3', eventId: data?.eventId ?? `${patientId}-painLevel-${iso}`, measurementKey: 'painLevel', valueNum: value, unit: '', measuredAt: iso }); }
        if (measurements?.respirations?.value != null) { const value = measurements.respirations.value; push('respiration', { resourceType: 'Observation', effectiveDateTime: iso, valueQuantity: { value, unit: 'breaths/min' } }, { vitalTypeCode: '9279-1', eventId: data?.eventId ?? `${patientId}-respiration-${iso}`, measurementKey: 'respiration', valueNum: value, unit: 'breaths/min', measuredAt: iso }); }
        const sys = measurements?.systolic?.value, dia = measurements?.diastolic?.value;
        if (sys != null && dia != null) { push('bloodPressure', { resourceType: 'Observation', effectiveDateTime: iso, component: [{ code: { coding: [{ code: '8480-6' }] }, valueQuantity: { value: sys, unit: 'mmHg' } }, { code: { coding: [{ code: '8462-4' }] }, valueQuantity: { value: dia, unit: 'mmHg' } }] }, [{ vitalTypeCode: '8480-6', eventId: data?.eventId ?? `${patientId}-systolic-${iso}`, measurementKey: 'systolic', valueNum: sys, unit: 'mmHg', measuredAt: iso }, { vitalTypeCode: '8462-4', eventId: data?.eventId ?? `${patientId}-diastolic-${iso}`, measurementKey: 'diastolic', valueNum: dia, unit: 'mmHg', measuredAt: iso }]); }
      });
      try { await conn.start(); await conn.invoke('SubscribeToPatient', patientId); connectionRef.current = conn; }
      catch (e) { console.error('VitalsHub connection error:', e); }
    })();
    return () => { isMounted = false; connectionRef.current?.stop().catch(() => { }); };
  }, [patientId, baseurl, canListObservation, upsertLatestVitalInSummaryAnalytics]);

  useEffect(() => {
    if (!canListObservation) { setVitalLoadingScoped(false); setVitalErrorScoped(null); return; }
    const already = loadedExtentPerVital[selectedVital] || 'today';
    if (extentRank[period] <= extentRank[already]) { setVitalLoadingScoped(false); setVitalErrorScoped(null); return; }
    const source = axios.CancelToken.source(); let mounted = true;
    (async () => {
      try {
        setVitalErrorScoped(null); setVitalLoadingScoped(true);
        const dateGtISO = getDateGtISO(period); const code = VITAL_CODES[selectedVital];
        const bundle = await fetchTotalObservation({ patientId, selectedFacilityId, code, dateGtISO, cancelToken: source.token });
        if (!mounted) return;
        setRawVitals(prev => ({ ...prev, [selectedVital]: bundle }));
        setVitalsData(prev => ({ ...prev, [selectedVital]: bundle }));
        setLoadedExtentPerVital(prev => ({ ...prev, [selectedVital]: period }));
      } catch (err: any) { if (!mounted) return; setVitalErrorScoped(err?.message || 'Failed to fetch selected vital.'); }
      finally { if (mounted) setVitalLoadingScoped(false); }
    })();
    return () => { mounted = false; source.cancel('unmounted'); };
  }, [period, selectedVital, patientId, selectedFacilityId, canListObservation, loadedExtentPerVital]);

  const formattedPhone = formatPhone(phone);

  // ─── Header chips ─────────────────────────────────────────────────────────
  const headerChips: { label: string; color: 'error' | 'warning' | 'default' | 'success'; icon?: React.ReactElement }[] = [];
  if (patient.allergies?.length) headerChips.push({ label: `${patient.allergies[0]} allergy`, color: 'error', icon: <WarningAmber sx={{ fontSize: 14 }} /> });
  if (fallPrediction && fallPrediction !== 'Normal') headerChips.push({ label: 'Fall risk', color: fallPrediction === 'High' || fallPrediction === 'Emergency' ? 'error' : 'warning' });
  if (patient.enrolledIn) headerChips.push({ label: patient.enrolledIn, color: 'default' });
  if (acuity.code) headerChips.push({ label: acuityName(acuity.code), color: acuityVariantMap[acuity.code as 'RED' | 'YELLOW' | 'GREEN'] });

  // Room/unit/floor/bed
  const normalizePart = (v?: string | null) => { if (!v) return null; const t = v.trim(); return (t && t.toUpperCase() !== 'N/A') ? t : null; };
  const locationParts = [normalizePart(floor), normalizePart(unit), normalizePart(room), normalizePart(bed)].filter(Boolean);

  // ─── Render tab content (unchanged logic) ─────────────────────────────────
  const renderTabContent = (tabId: TabId) => {
    if (tabId === 'overview') {
      if (!canListObservation) return <Alert severity="warning">Access Restricted: You don't have permission to view {resourceDisplayName['Observation']}.</Alert>;
      if (vitalsLoading) return renderSkeletonForTab(tabId);
